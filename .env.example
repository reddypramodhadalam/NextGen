# AITAS - AI Test Automation System
# Environment Configuration Template
# Copy this file to .env and configure your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection (used by docker-compose)
POSTGRES_USER=aitas
POSTGRES_PASSWORD=change_this_to_secure_password
POSTGRES_DB=aitas
POSTGRES_PORT=5432

# Full database URL (used by application)
# When using docker-compose, this is auto-configured
# For external database, set this manually:
# DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Port the application runs on
APP_PORT=5000

# Session secret for authentication (CHANGE THIS!)
# Generate with: openssl rand -base64 32
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_characters

# Node environment
NODE_ENV=production

# =============================================================================
# AI/LLM CONFIGURATION
# =============================================================================

# Option 1: OpenAI API (recommended)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Option 2: Custom LLM (Azure OpenAI, local LLM, etc.)
# LLM_API_URL=https://your-llm-endpoint.com/v1/chat/completions
# LLM_BEARER_TOKEN=your-bearer-token

# =============================================================================
# SELENIUM GRID (Optional - for distributed testing)
# =============================================================================

# Enable Selenium Grid by running: docker-compose --profile selenium up
SELENIUM_HUB_PORT=4444

# =============================================================================
# MASTER ADMIN ACCOUNT
# =============================================================================

# Default master admin credentials (created on first run)
# IMPORTANT: Change the password after first login!
# Email: admin@aitas.com
# Password: AitasMaster2024!

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================

# SMTP Configuration (for email notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=aitas@example.com

# Slack Webhook (for notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# =============================================================================
# BROWSER AUTOMATION SETTINGS
# =============================================================================

# Default browser for test execution
# Options: chromium, firefox, webkit
DEFAULT_BROWSER=chromium

# Browser headless mode (true for production)
BROWSER_HEADLESS=true

# Screenshot quality (0-100)
SCREENSHOT_QUALITY=80

# Default timeout for test steps (milliseconds)
DEFAULT_TIMEOUT=30000
