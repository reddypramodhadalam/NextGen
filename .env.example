# ============================================================================
#  AITAS — Environment Configuration (example)
#  Copy to ".env" and fill in real values.  Never commit your real .env.
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/aitas
SESSION_SECRET=change-me-to-a-long-random-string
PORT=5000

# ── AI / LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_API_URL=https://api.openai.com/v1

# ── Browser SSO / Single Sign-On ────────────────────────────────────────────
# Apps behind Microsoft Entra / Okta / ADFS (JD Edwards, SAP Fiori, Salesforce)
# need a logged-in browser session. By default AITAS uses a fresh, empty Chrome
# profile that has NO session, so the IdP forces a login page mid-test.
#
# Set REUSE_BROWSER_PROFILE=true to reuse a PERSISTENT Chrome profile: sign in
# ONCE (interactively, headed), and the SSO cookie is reused on every run —
# exactly like your normal browser. JDE then opens straight to Fast Path.
# ON by default. Set to "false" only to force a clean, throwaway profile.
REUSE_BROWSER_PROFILE=true

# Folder for the persistent profile (auto-created). Use a DEDICATED folder, and
# close other Chrome windows using it before a run (Chrome locks the profile).
# Default if unset: <home>/.aitas/chrome-profile
CHROME_PROFILE_DIR=
