# ============================================================================
#  AITAS — Environment Configuration (example)
#  Copy to ".env" and fill in real values.  Never commit your real .env.
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/aitas
SESSION_SECRET=change-me-to-a-long-random-string
PORT=5000

# ── AI / LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_API_URL=https://api.openai.com/v1

# Max time (ms) to wait for a single LLM response. "Comprehensive" depth asks
# the model for 25-35 detailed test cases, which can take several minutes on a
# corporate gateway. If this is too low the request aborts and AITAS falls back
# to the deterministic rule-based generator. Default 180000 (180s).
LLM_TIMEOUT_MS=300000

# ── Browser SSO / Single Sign-On ────────────────────────────────────────────
# Apps behind Microsoft Entra / Okta / ADFS (JD Edwards, SAP Fiori, Salesforce)
# need a logged-in browser session. By default AITAS uses a fresh, empty Chrome
# profile that has NO session, so the IdP forces a login page mid-test.
#
# Set REUSE_BROWSER_PROFILE=true to reuse a PERSISTENT Chrome profile: sign in
# ONCE (interactively, headed), and the SSO cookie is reused on every run —
# exactly like your normal browser. JDE then opens straight to Fast Path.
# ON by default. Set to "false" only to force a clean, throwaway profile.
REUSE_BROWSER_PROFILE=true

# Folder for the persistent profile (auto-created). Use a DEDICATED folder, and
# close other Chrome windows using it before a run (Chrome locks the profile).
# Default if unset: <home>/.aitas/chrome-profile
CHROME_PROFILE_DIR=

# ── JDE classic form-login (OPTIONAL) ───────────────────────────────────────
# Leave these BLANK when JDE is behind SSO (Entra/Okta) — AITAS will drive JDE
# through the AI/DOM executor using the persistent Chrome profile above.
#
# Set them ONLY for classic JD Edwards that shows a username/password login form.
# When BOTH JDE_USERNAME and JDE_PASSWORD are present, the Enterprise Router
# dispatches JDE runs to the dedicated jdeExecutor (form login + AIS REST).
JDE_USERNAME=
JDE_PASSWORD=
# Optional: defaults to the test's target URL when blank.
JDE_BASE_URL=
# Optional: AIS REST base for orchestrator/data-service calls.
JDE_AIS_URL=
# Optional JDE login context.
JDE_ENVIRONMENT=
JDE_ROLE=
JDE_API_VERSION=
